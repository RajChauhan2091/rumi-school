@model SchoolManagement.Domain.Entities.SemesterMaster
@{
    ViewData["Title"] = "Edit Semester";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>Edit Semester</h5>
            </div>
            <div class="card-body-custom">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="SemesterID" />
                    
                    <div class="mb-3">
                        <label asp-for="SemesterName" class="form-label fw-medium">Semester Name</label>
                        <input asp-for="SemesterName" type="text" class="form-control" placeholder="e.g. Semester 1" required maxlength="30" />
                        <span asp-validation-for="SemesterName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" id="semActiveSwitch" />
                            <label class="form-check-label" for="semActiveSwitch">Is Active</label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
