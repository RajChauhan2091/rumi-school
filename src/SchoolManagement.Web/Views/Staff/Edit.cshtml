@model SchoolManagement.Domain.Entities.StaffDetail
@{
    ViewData["Title"] = "Edit Staff Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="content-card animate-in">
            <div class="card-header-crimson">
                <h5><i class="bi bi-pencil-square me-1" style="font-size: 0.85rem; color: var(--primary);"></i> Edit Staff Profile</h5>
            </div>
            <div class="card-body-custom">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="StaffID" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h6 class="border-bottom pb-2 mb-3 text-secondary text-uppercase fs-7 fw-bold" style="letter-spacing: 0.5px;">Personal Information</h6>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="StaffFirstName" class="form-label fw-medium">First Name</label>
                            <input asp-for="StaffFirstName" class="form-control" placeholder="First Name" />
                            <span asp-validation-for="StaffFirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StaffMiddleName" class="form-label fw-medium">Middle Name</label>
                            <input asp-for="StaffMiddleName" class="form-control" placeholder="Middle Name" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StaffLastName" class="form-label fw-medium">Last Name</label>
                            <input asp-for="StaffLastName" class="form-control" placeholder="Last Name" />
                            <span asp-validation-for="StaffLastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="StaffType" class="form-label fw-medium">Staff Role</label>
                            <select asp-for="StaffType" asp-items="ViewBag.StaffTypes" class="form-select">
                                <option value="">-- Select Role Type --</option>
                            </select>
                            <span asp-validation-for="StaffType" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DOB" class="form-label fw-medium">Date of Birth</label>
                            <input asp-for="DOB" type="date" class="form-control" />
                            <span asp-validation-for="DOB" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">Change Photo (Optional)</label>
                            <input type="file" name="staffPicFile" class="form-control" accept="image/*" />
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-secondary text-uppercase fs-7 fw-bold mt-4" style="letter-spacing: 0.5px;">Contact Details</h6>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Mobileno" class="form-label fw-medium">Primary Mobile No</label>
                            <input asp-for="Mobileno" class="form-control" />
                            <span asp-validation-for="Mobileno" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmergencyContact" class="form-label fw-medium">Emergency Mobile No</label>
                            <input asp-for="EmergencyContact" class="form-control" />
                            <span asp-validation-for="EmergencyContact" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="AddressLine1" class="form-label fw-medium">Address Line 1</label>
                            <input asp-for="AddressLine1" class="form-control" placeholder="House No, Street, Landmark" />
                            <span asp-validation-for="AddressLine1" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AddressLine2" class="form-label fw-medium">Address Line 2 (Optional)</label>
                            <input asp-for="AddressLine2" class="form-control" placeholder="Locality, Area" />
                            <span asp-validation-for="AddressLine2" class="text-danger"></span>
                        </div>
                    </div>

                    <h6 class="border-bottom pb-2 mb-3 text-secondary text-uppercase fs-7 fw-bold mt-4" style="letter-spacing: 0.5px;">Verification & Financials (Optional)</h6>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="AadhaarNo" class="form-label fw-medium">Aadhaar Number (Optional)</label>
                            <input asp-for="AadhaarNo" class="form-control" maxlength="14" placeholder="1234-5678-9012" id="staffAadhaarInput" />
                            <span asp-validation-for="AadhaarNo" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PanNo" class="form-label fw-medium">PAN Card Number (Optional)</label>
                            <input asp-for="PanNo" class="form-control" />
                            <span asp-validation-for="PanNo" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BankName" class="form-label fw-medium">Bank Name (Optional)</label>
                            <input asp-for="BankName" class="form-control" />
                            <span asp-validation-for="BankName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="AccountNo" class="form-label fw-medium">Bank Account Number (Optional)</label>
                            <input asp-for="AccountNo" class="form-control" />
                            <span asp-validation-for="AccountNo" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IFSCCode" class="form-label fw-medium">Bank IFSC Code (Optional)</label>
                            <input asp-for="IFSCCode" class="form-control" />
                            <span asp-validation-for="IFSCCode" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" id="staffActiveSwitch" />
                            <label class="form-check-label" for="staffActiveSwitch">Is Active</label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const aadhaarInput = document.getElementById('staffAadhaarInput');
            if (aadhaarInput) {
                aadhaarInput.addEventListener('input', function (e) {
                    let value = e.target.value.replace(/\D/g, '');
                    if (value.length > 12) {
                        value = value.slice(0, 12);
                    }
                    let formatted = '';
                    for (let i = 0; i < value.length; i++) {
                        if (i > 0 && i % 4 === 0) {
                            formatted += '-';
                        }
                        formatted += value[i];
                    }
                    e.target.value = formatted;
                });
            }
        });
    </script>
}
