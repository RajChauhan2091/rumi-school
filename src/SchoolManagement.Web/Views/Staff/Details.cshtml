@model SchoolManagement.Domain.Entities.StaffDetailsView
@{
    ViewData["Title"] = "Staff Profile Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card animate-in">
            <div class="card-header-crimson">
                <h5><i class="bi bi-person-badge me-1" style="font-size: 0.85rem; color: var(--primary);"></i> Staff Profile Details</h5>
                <a asp-action="Index" class="btn btn-sm btn-secondary"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
            </div>
            <div class="card-body-custom">
                <div class="d-flex align-items-center gap-4 mb-4 pb-3 border-bottom">
                    @if (!string.IsNullOrEmpty(Model.StaffPic))
                    {
                        <img src="data:image/jpeg;base64,@Model.StaffPic" class="rounded border" style="width: 100px; height: 100px; object-fit: cover;" alt="Staff" />
                    }
                    else
                    {
                        <div class="rounded bg-secondary text-white d-flex align-items-center justify-content-center border" style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: bold;">
                            @Model.StaffFirstName.Substring(0, Math.Min(1, Model.StaffFirstName.Length))@Model.StaffLastName.Substring(0, Math.Min(1, Model.StaffLastName.Length))
                        </div>
                    }
                    <div>
                        <h4 class="mb-1 text-primary">@Model.StaffFullName</h4>
                        <span class="badge bg-primary fs-6">@Model.StaffTypeName</span>
                        <div class="mt-2 text-muted"><i class="bi bi-telephone-fill me-1"></i> @Model.Mobileno</div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr>
                                <th class="w-30 bg-light fw-semibold text-muted">Aadhaar Number</th>
                                <td>
                                    @(!string.IsNullOrEmpty(Model.AadhaarNo) && Model.AadhaarNo.Length == 12 
                                        ? $"{Model.AadhaarNo.Substring(0, 4)}-{Model.AadhaarNo.Substring(4, 4)}-{Model.AadhaarNo.Substring(8, 4)}" 
                                        : Model.AadhaarNo ?? "-")
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">PAN Card Number</th>
                                <td>@Model.PanNo</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Date of Birth</th>
                                <td>@Model.DOB.ToString("dd-MM-yyyy")</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Emergency Contact</th>
                                <td>@Model.EmergencyContact</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Residential Address</th>
                                <td>
                                    @Model.AddressLine1
                                    @if (!string.IsNullOrEmpty(Model.AddressLine2))
                                    {
                                        <br />@Model.AddressLine2
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Bank Name</th>
                                <td>@Model.BankName</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Account Number</th>
                                <td>@Model.AccountNo</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">IFSC Code</th>
                                <td>@Model.IFSCCode</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Status</th>
                                <td>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.StaffID" class="btn btn-primary"><i class="bi bi-pencil-fill me-1"></i> Edit Profile</a>
                </div>
            </div>
        </div>
    </div>
</div>
