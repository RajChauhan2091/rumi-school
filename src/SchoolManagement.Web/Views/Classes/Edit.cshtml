@model SchoolManagement.Domain.Entities.ClassMaster
@{
    ViewData["Title"] = "Edit Class";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>Edit Class - @Model.ClassName</h5>
            </div>
            <div class="card-body-custom">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="ClassId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="ClassName" class="form-label fw-medium">Class Name</label>
                        <input asp-for="ClassName" class="form-control" />
                        <span asp-validation-for="ClassName" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" id="classActiveSwitch" />
                            <label class="form-check-label" for="classActiveSwitch">Is Active</label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
