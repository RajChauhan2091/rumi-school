@model SchoolManagement.Domain.Entities.PaymentDetail
@{
    var student = (SchoolManagement.Domain.Entities.StudentDetailsView)ViewBag.Student;
    ViewData["Title"] = "Edit Payment Record";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">
        <div class="content-card shadow-sm border rounded-3 bg-white">
            <div class="card-header-crimson p-3 rounded-top-3">
                <h5 class="mb-0 text-white"><i class="bi bi-pencil-square me-2"></i>Edit Fee Payment Record</h5>
            </div>
            <div class="card-body-custom p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="PaymentDetailID" />
                    <input type="hidden" asp-for="StudentID" />
                    <input type="hidden" asp-for="FinancialYearID" />
                    <input type="hidden" asp-for="FeeID" />
                    <input type="hidden" asp-for="SemesterID" />
                    <input type="hidden" asp-for="IsFullyPaid" />

                    <!-- Read-Only Student Info Header -->
                    <div class="card bg-light border-0 mb-4 shadow-sm">
                        <div class="card-body p-3">
                            <h6 class="text-muted text-uppercase fs-7 fw-bold mb-2">Student & Semester Details</h6>
                            <div class="row align-items-center">
                                <div class="col-md-9">
                                    <h5 class="text-primary mb-1 fw-bold">@student.FullName</h5>
                                    <div class="row text-muted small mt-2">
                                        <div class="col-sm-6 mb-1">
                                            <strong>GR No:</strong> <span>@student.GrNo</span>
                                        </div>
                                        <div class="col-sm-6 mb-1">
                                            <strong>Class:</strong> <span>@student.ClassName</span>
                                        </div>
                                        <div class="col-sm-6">
                                            <strong>Semester:</strong> <span>@ViewBag.FeeStructures.SelectedValue</span>
                                        </div>
                                        <div class="col-sm-6">
                                            <strong>Receipt Number:</strong> <span>RUMI-@($"{Model.PaymentDetailID:D3}")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FeePaid" class="form-label fw-bold text-dark">Amount Paid (₹)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">₹</span>
                                <input asp-for="FeePaid" type="number" step="0.01" min="0.01" class="form-control fw-bold text-primary" required />
                            </div>
                            <span asp-validation-for="FeePaid" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="TotalInstallment" class="form-label fw-bold text-dark">Installment #</label>
                            <input asp-for="TotalInstallment" type="number" class="form-control" min="1" max="12" required />
                            <span asp-validation-for="TotalInstallment" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PaymentMode" class="form-label fw-bold text-dark">Payment Mode</label>
                            <select asp-for="PaymentMode" class="form-select" id="paymentModeSelect" onchange="toggleOnlineDetails()" required>
                                <option value="Cash">Cash</option>
                                <option value="UPI">UPI</option>
                                <option value="Card">Debit/Credit Card</option>
                                <option value="NetBanking">Net Banking</option>
                                <option value="Cheque">Cheque</option>
                            </select>
                            <span asp-validation-for="PaymentMode" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-dark">Update Screenshot / Receipt Photo</label>
                            <input type="file" name="transactionPhotoFile" class="form-control" accept="image/*" />
                            <span class="text-muted small fs-8">Leave empty to retain the current screenshot.</span>
                        </div>
                    </div>

                    <div id="onlineDetailsDiv" class="mb-4" style="display:none;">
                        <div class="card border-dashed p-3 bg-light">
                            <div class="mb-0">
                                <label asp-for="TransactionRef" class="form-label fw-semibold text-dark">Transaction / Reference Number</label>
                                <input asp-for="TransactionRef" class="form-control" placeholder="Enter UPI Trans ID / Cheque No / Reference" id="txRefInput" />
                                <span asp-validation-for="TransactionRef" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <label asp-for="Remarks" class="form-label fw-bold text-dark">Remarks / Payment Notes</label>
                            <textarea asp-for="Remarks" class="form-control" rows="2" placeholder="e.g. Updated reference ID, verified by bank statement..."></textarea>
                            <span asp-validation-for="Remarks" class="text-danger small"></span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Transactionphoto))
                    {
                        <div class="border rounded p-3 text-center bg-light mb-4">
                            <span class="text-muted small d-block mb-2">Current Photo Receipt</span>
                            <img src="data:image/jpeg;base64,@Model.Transactionphoto" class="img-thumbnail" style="max-height: 150px;" alt="Current Receipt" />
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center border-top pt-4">
                        <a asp-action="StudentLedger" asp-route-studentId="@Model.StudentID" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left"></i> Cancel</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save"></i> Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            toggleOnlineDetails();
        });

        function toggleOnlineDetails() {
            var mode = $('#paymentModeSelect').val();
            var onlineDiv = $('#onlineDetailsDiv');
            var refInput = $('#txRefInput');

            if (mode === 'Cash') {
                onlineDiv.slideUp();
                refInput.removeAttr('required');
            } else {
                onlineDiv.slideDown();
                refInput.attr('required', 'required');
            }
        }
    </script>
}
