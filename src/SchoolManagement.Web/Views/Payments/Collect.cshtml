@model SchoolManagement.Domain.Entities.PaymentDetail
@{
    var activeFY = (SchoolManagement.Domain.Entities.FinancialYear)ViewBag.ActiveFY;
    ViewData["Title"] = "Collect Fee Payment";
}

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="content-card shadow-lg border-0 rounded-3 animate-in">
            <div class="card-header-crimson p-4 rounded-top-3">
                <h4 class="mb-0 text-white"><i class="bi bi-receipt me-2"></i>Fee Collection Slip</h4>
            </div>
            <div class="card-body-custom p-4">
                <form asp-action="Collect" method="post" enctype="multipart/form-data" id="paymentForm">
                    <input type="hidden" asp-for="StudentID" id="hiddenStudentId" />
                    <input type="hidden" asp-for="FinancialYearID" value="@activeFY.FinancialYearId" />
                    <input type="hidden" asp-for="SemesterID" id="hiddenSemesterId" />
                    <input type="hidden" asp-for="IsFullyPaid" id="hiddenIsFullyPaid" />

                    <!-- Search and Select Student Section -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-dark"><i class="bi bi-search me-1 text-primary"></i> Search and Select Student</label>
                            <div class="input-group mb-2">
                                <span class="input-group-text bg-light"><i class="bi bi-person-fill text-muted"></i></span>
                                <input type="text" id="studentSearchInput" class="form-control" placeholder="Type student name or GR number to search..." autocomplete="off" />
                            </div>
                            <select id="studentSelect" class="form-select select-searchable" required size="5">
                                <option value="">-- Type search above to filter students --</option>
                                @foreach (var item in (SelectList)ViewBag.Students)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Selected Student Profile Info Card -->
                    <div id="studentProfileCard" class="card bg-light border-0 mb-4 shadow-sm" style="display: none;">
                        <div class="card-body p-3">
                            <div class="row align-items-center">
                                <div class="col-md-2 text-center d-none d-md-block">
                                    <div class="avatar bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px; font-size: 24px; font-weight: bold;" id="profileAvatar">
                                        ST
                                    </div>
                                </div>
                                <div class="col-md-10">
                                    <h5 class="text-primary mb-1 fw-bold" id="profileFullName">Student Name</h5>
                                    <div class="row text-muted small">
                                        <div class="col-sm-6 mb-1">
                                            <strong>GR No:</strong> <span id="profileGrNo">GR-1001</span>
                                        </div>
                                        <div class="col-sm-6 mb-1">
                                            <strong>Class:</strong> <span id="profileClass">Class 10 (A)</span>
                                        </div>
                                        <div class="col-sm-6">
                                            <strong>Roll No:</strong> <span id="profileRollNo">1</span>
                                        </div>
                                        <div class="col-sm-6">
                                            <strong>Academic Year:</strong> <span>@activeFY.FinancialYearName</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fee Selection -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-dark"><i class="bi bi-wallet2 me-1 text-primary"></i> Mapped Semester Fee Structure</label>
                            <select asp-for="FeeID" class="form-select" id="feeSelect" required disabled>
                                <option value="">-- Choose Student First --</option>
                            </select>
                            <span asp-validation-for="FeeID" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Ledger / Balance Calculation Visualizer -->
                    <div id="ledgerCard" class="card border-primary-subtle bg-white mb-4 shadow-sm" style="display: none;">
                        <div class="card-header bg-primary-subtle py-2">
                            <h6 class="mb-0 text-primary-emphasis fw-bold"><i class="bi bi-calculator me-1"></i> Fee Balance calculation</h6>
                        </div>
                        <div class="card-body p-3">
                            <div class="row text-center">
                                <div class="col-4 border-end">
                                    <span class="text-muted d-block small mb-1">Total Mapped Fee</span>
                                    <h5 class="fw-bold mb-0 text-dark" id="lblTotalFee">₹ 0.00</h5>
                                </div>
                                <div class="col-4 border-end">
                                    <span class="text-muted d-block small mb-1">Paid So Far</span>
                                    <h5 class="fw-bold mb-0 text-success" id="lblPaidSoFar">₹ 0.00</h5>
                                </div>
                                <div class="col-4">
                                    <span class="text-muted d-block small mb-1">Outstanding Balance</span>
                                    <h5 class="fw-bold mb-0 text-danger" id="lblRemainingBalance">₹ 0.00</h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fee Paid & Calculation fields -->
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FeePaid" class="form-label fw-bold text-dark">Amount Paid Now (₹)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">₹</span>
                                <input asp-for="FeePaid" type="number" step="0.01" min="0.01" class="form-control fw-bold text-primary" placeholder="0.00" id="feePaidInput" required disabled />
                            </div>
                            <span asp-validation-for="FeePaid" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium text-muted">Remaining Balance After Payment (₹)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">₹</span>
                                <input type="text" id="newRemainingInput" class="form-control bg-light fw-bold" readonly placeholder="0.00" />
                            </div>
                        </div>
                    </div>

                    <!-- Payment Mode & Photo Receipt -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="PaymentMode" class="form-label fw-bold text-dark">Payment Mode</label>
                            <select asp-for="PaymentMode" class="form-select" id="paymentModeSelect" onchange="toggleOnlineDetails()" required>
                                <option value="Cash">Cash</option>
                                <option value="UPI">UPI</option>
                                <option value="Card">Debit/Credit Card</option>
                                <option value="NetBanking">Net Banking</option>
                                <option value="Cheque">Cheque</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Upload Receipt / Screenshot photo <span class="text-danger">*</span></label>
                            <input type="file" name="transactionPhotoFile" class="form-control" accept="image/*" required />
                            <span class="text-muted small fs-8">Allowed files: JPG, PNG, WebP. Receipt photo is mandatory.</span>
                        </div>
                    </div>

                    <!-- Online transaction details wrapper -->
                    <div id="onlineDetailsDiv" class="mb-4" style="display:none;">
                        <div class="card border-dashed p-3 bg-light">
                            <div class="mb-0">
                                <label asp-for="TransactionRef" class="form-label fw-semibold text-dark">Transaction / Reference Number</label>
                                <input asp-for="TransactionRef" class="form-control" placeholder="Enter UPI Trans ID / Cheque No / Reference" id="txRefInput" />
                                <span asp-validation-for="TransactionRef" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Installment & Info -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="TotalInstallment" class="form-label fw-bold text-dark">Installment #</label>
                            <input asp-for="TotalInstallment" type="number" class="form-control" min="1" max="12" required />
                            <span asp-validation-for="TotalInstallment" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="alert alert-info py-2 px-3 mb-0 w-100 fs-7">
                                <i class="bi bi-info-circle-fill me-1 text-primary"></i> If outstanding balance becomes zero, the receipt is automatically marked as **Fully Paid**.
                            </div>
                        </div>
                    </div>

                    <!-- Remarks -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <label asp-for="Remarks" class="form-label fw-bold text-dark">Remarks / Payment Notes</label>
                            <textarea asp-for="Remarks" class="form-control" rows="2" placeholder="e.g. Cash handed over to clerk, Sem-1 full payment..."></textarea>
                            <span asp-validation-for="Remarks" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Footer Actions -->
                    <div class="d-flex justify-content-end gap-2 border-top pt-4">
                        <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                        <button type="submit" class="btn btn-success px-4" id="btnSubmit" disabled><i class="bi bi-check-circle-fill me-1"></i> Post Payment</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var allStudents = [];
        var selectedStudentFeeData = [];

        $(document).ready(function() {
            // Keep copy of students list
            $('#studentSelect option').each(function() {
                if ($(this).val()) {
                    allStudents.push({
                        id: $(this).val(),
                        text: $(this).text()
                    });
                }
            });

            // Student Search Input
            $('#studentSearchInput').on('input', function() {
                var query = $(this).val().toLowerCase();
                var select = $('#studentSelect');
                select.empty();
                
                var filtered = allStudents.filter(function(s) {
                    return s.text.toLowerCase().indexOf(query) > -1;
                });

                if (filtered.length === 0) {
                    select.append('<option value="">-- No matching students found --</option>');
                } else {
                    filtered.forEach(function(s) {
                        select.append('<option value="' + s.id + '">' + s.text + '</option>');
                    });
                }
            });

            // Handle student selection change
            $('#studentSelect').on('change', function() {
                var studentId = $(this).val();
                if (!studentId) {
                    resetForm();
                    return;
                }
                
                $('#hiddenStudentId').val(studentId);
                
                // Fetch student fee mapping status via AJAX
                $.ajax({
                    url: '/Payments/GetStudentFeeStatusJson?studentId=' + studentId,
                    type: 'GET',
                    beforeSend: function() {
                        $('#feeSelect').prop('disabled', true).empty().append('<option value="">Loading student fees...</option>');
                    },
                    success: function(res) {
                        if (res.success) {
                            selectedStudentFeeData = res.fees;
                            
                            // Display student info card
                            $('#profileFullName').text(res.student.fullName);
                            $('#profileGrNo').text(res.student.grNo);
                            $('#profileClass').text(res.student.className + ' (' + res.student.divisionName + ')');
                            $('#profileRollNo').text(res.student.rollNo);
                            $('#profileAvatar').text(res.student.fullName.substring(0,2).toUpperCase());
                            $('#studentProfileCard').slideDown();

                            // Populate mapped fees
                            var feeSelect = $('#feeSelect');
                            feeSelect.empty();
                            
                            if (res.fees.length === 0) {
                                feeSelect.append('<option value="">-- No fee structure mapped for student\'s class --</option>');
                                $('#feePaidInput').prop('disabled', true);
                                $('#btnSubmit').prop('disabled', true);
                            } else {
                                feeSelect.prop('disabled', false);
                                feeSelect.append('<option value="">-- Select Mapped Semester Fee --</option>');
                                
                                res.fees.forEach(function(f) {
                                    var text = f.semesterName + ' (Fee: ₹' + f.feeAmount.toFixed(2) + ' | Rem: ₹' + f.remainingBalance.toFixed(2) + ')';
                                    var disabledAttr = f.remainingBalance <= 0 ? ' disabled' : '';
                                    feeSelect.append('<option value="' + f.feeId + '"' + disabledAttr + ' data-semesterid="' + f.semesterId + '">' + text + '</option>');
                                });

                                $('#btnSubmit').prop('disabled', false);
                            }
                        } else {
                            alert(res.message);
                            resetForm();
                        }
                    },
                    error: function() {
                        alert('Error loading fee details.');
                        resetForm();
                    }
                });
            });

            // Handle fee selection change
            $('#feeSelect').on('change', function() {
                var feeId = $(this).val();
                if (!feeId) {
                    $('#ledgerCard').hide();
                    $('#feePaidInput').prop('disabled', true).val('');
                    $('#newRemainingInput').val('');
                    return;
                }

                var selectedOption = $('#feeSelect option:selected');
                var semId = selectedOption.attr('data-semesterid');
                $('#hiddenSemesterId').val(semId);

                // Find corresponding fee config in JS data array
                var feeConfig = selectedStudentFeeData.find(function(f) {
                    return f.feeId == feeId && f.semesterId == semId;
                });

                if (feeConfig) {
                    // Update visualizer labels
                    $('#lblTotalFee').text('₹ ' + feeConfig.feeAmount.toFixed(2));
                    $('#lblPaidSoFar').text('₹ ' + feeConfig.totalPaid.toFixed(2));
                    $('#lblRemainingBalance').text('₹ ' + feeConfig.remainingBalance.toFixed(2));
                    $('#ledgerCard').slideDown();

                    // Update inputs
                    $('#feePaidInput').prop('disabled', false).val(feeConfig.remainingBalance.toFixed(2)).attr('max', feeConfig.remainingBalance);
                    $('#newRemainingInput').val('0.00');
                    $('#hiddenIsFullyPaid').val('true');
                }
            });

            // Calculate remaining balance dynamically
            $('#feePaidInput').on('input', function() {
                var paidNow = parseFloat($(this).val()) || 0;
                var feeId = $('#feeSelect').val();
                var semId = $('#hiddenSemesterId').val();

                var feeConfig = selectedStudentFeeData.find(function(f) {
                    return f.feeId == feeId && f.semesterId == semId;
                });

                if (feeConfig) {
                    var remaining = feeConfig.remainingBalance - paidNow;
                    if (remaining < 0) remaining = 0;
                    
                    $('#newRemainingInput').val(remaining.toFixed(2));
                    $('#hiddenIsFullyPaid').val(remaining <= 0 ? 'true' : 'false');
                }
            });

            // If a studentId was pre-selected, trigger the select change event
            var preSelectedVal = $('#studentSelect').val();
            if (preSelectedVal) {
                $('#studentSelect').trigger('change');
            }
        });

        function resetForm() {
            $('#studentProfileCard').hide();
            $('#ledgerCard').hide();
            $('#feeSelect').prop('disabled', true).empty().append('<option value="">-- Choose Student First --</option>');
            $('#feePaidInput').prop('disabled', true).val('');
            $('#newRemainingInput').val('');
            $('#btnSubmit').prop('disabled', true);
            $('#hiddenStudentId').val('');
            $('#hiddenSemesterId').val('');
        }

        function toggleOnlineDetails() {
            var mode = $('#paymentModeSelect').val();
            var onlineDiv = $('#onlineDetailsDiv');
            var refInput = $('#txRefInput');

            if (mode === 'Cash') {
                onlineDiv.slideUp();
                refInput.removeAttr('required');
            } else {
                onlineDiv.slideDown();
                refInput.attr('required', 'required');
            }
        }
    </script>
}
